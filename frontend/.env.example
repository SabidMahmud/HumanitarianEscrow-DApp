# HumanitarianEscrow frontend environment template
#
# Setup:
# 1) Copy this file to `.env` in the `frontend` directory.
#    cp .env.example .env
# 2) Deploy contracts with Truffle.
# 3) Paste the deployed `HumanitarianEscrow` contract address below.
#
# Important:
# - `NEXT_PUBLIC_` variables are exposed to the browser.
# - Do NOT add private keys, seed phrases, or any secret credentials here.
# - Address format must be: 0x + 40 hexadecimal characters.
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS
